# Update Ubuntu
sudo apt update
sudo apt upgrade -y

# Install required packages
sudo apt install -y curl git build-essential

# Install Node.js (LTS)
curl -fsSL https://deb.nodesource.com/setup_lts.x | sudo -E bash -
sudo apt install -y nodejs

# Verify installation
node -v
npm -v

# Install OpenCode AI
sudo npm install -g opencode-ai

# Verify installation
opencode --version

# Start OpenCode
opencode
